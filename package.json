{
  "name": "trd-lite",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "codegen:dump-schema": "tsx scripts/dump-schema.ts",
    "codegen": "pnpm codegen:dump-schema && graphql-codegen --config codegen.ts",
    "codegen:check": "pnpm codegen && tsx scripts/check-codegen-clean.ts"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.33",
    "@neondatabase/serverless": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dataloader": "^2.2.3",
    "drizzle-orm": "^0.45.2",
    "graphql": "^16.14.0",
    "graphql-scalars": "^1.25.0",
    "graphql-yoga": "^5.21.0",
    "he": "^1.2.0",
    "lucide-react": "^1.14.0",
    "next": "^15.5.18",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "^2.17.3",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/typescript": "^6.0.1",
    "@graphql-codegen/typescript-operations": "^6.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/he": "^1.2.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.5",
    "axe-core": "^4.11.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^15.5.18",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
