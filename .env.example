# =====================================================================
# TRD Lite environment template
# Copy this file to .env.local and fill in real values, or run:
#   vercel env pull .env.local
# =====================================================================

# Neon Postgres connection (pooled). Used by the app at runtime.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Neon Postgres connection (direct, unpooled). Used by drizzle-kit migrate
# and drizzle-kit studio. Pooled connections do not allow long-lived
# transactions or interactive sessions.
DATABASE_URL_UNPOOLED="postgresql://user:password@host.region.aws.neon.tech/neondb?sslmode=require"

# WordPress REST API base. Sync worker reads from here. No trailing slash.
WP_BASE_URL="https://therealdeal.com/wp-json/wp/v2"

# Bearer token required by /api/sync. Vercel Cron sends this automatically.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SYNC_TOKEN="replace-me-with-a-32-byte-hex-string"

# HTTP Basic Auth credentials for /admin/* (force-sync UI).
# Middleware enforces these on every /admin request.
ADMIN_USER="admin"
ADMIN_PASS="replace-me-with-a-strong-password"
